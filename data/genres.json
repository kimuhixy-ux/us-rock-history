{
  "categories": [
    {
      "id": "rock-and-roll",
      "label": "ロックンロール / ロカビリー",
      "period": "1950s",
      "description": "R&Bとカントリーが融合して生まれた、アメリカン・ロックの原点。"
    },
    {
      "id": "folk-rock",
      "label": "フォークロック",
      "period": "1960s",
      "description": "フォークの弾き語り文化にエレクトリックなバンドサウンドを持ち込んだジャンル。"
    },
    {
      "id": "surf-garage-rock",
      "label": "サーフロック / ガレージロック",
      "period": "1960s",
      "description": "西海岸のサーフカルチャーと、地元のティーンバンドが荒っぽく鳴らすガレージサウンド。"
    },
    {
      "id": "psychedelic-rock",
      "label": "サイケデリックロック",
      "period": "1960s",
      "description": "幻覚的・実験的なサウンドと即興演奏を追求した西海岸中心のロック。"
    },
    {
      "id": "southern-rock",
      "label": "サザンロック",
      "period": "1970s",
      "description": "ブルースとカントリーを土台に、南部特有の泥臭いグルーヴを鳴らすロック。"
    },
    {
      "id": "arena-hard-rock",
      "label": "アリーナロック / ハードロック",
      "period": "1970s",
      "description": "巨大な会場を埋めるスケール感を志向した、歪んだギターと派手な演出のロック。グラム/ショックロックも含む。"
    },
    {
      "id": "proto-punk",
      "label": "プロトパンク",
      "period": "1970s",
      "description": "過剰なプロダクションへの反動として、荒々しく原始的な衝動を鳴らしたパンク前夜のロック。"
    },
    {
      "id": "punk-rock",
      "label": "パンクロック",
      "period": "1970s",
      "description": "ニューヨークのクラブシーンから生まれた、シンプルで速く攻撃的なロック。"
    },
    {
      "id": "new-wave",
      "label": "ニューウェイヴ",
      "period": "1970s-1980s",
      "description": "パンクの精神を保ちつつ、シンセサイザーやポップな感覚を取り入れた都会的なロック。"
    },
    {
      "id": "hardcore-punk",
      "label": "ハードコアパンク",
      "period": "1980s",
      "description": "パンクをさらに速く短く先鋭化させた、DIYシーン発の攻撃的なジャンル。"
    },
    {
      "id": "college-rock-indie",
      "label": "カレッジロック / インディーロック",
      "period": "1980s",
      "description": "大学ラジオ局を中心に支持された、メジャーとは距離を置く独立系のギターロック。"
    },
    {
      "id": "glam-metal",
      "label": "グラムメタル(ヘアメタル)",
      "period": "1980s",
      "description": "派手な化粧・髪型とキャッチーなコーラスを組み合わせた、ロサンゼルス発のメタル。"
    },
    {
      "id": "heavy-metal",
      "label": "ヘヴィメタル(スラッシュメタル含む)",
      "period": "1980s",
      "description": "攻撃性と超絶技巧を追求したメタル。ハードコアの速さを取り込んだスラッシュメタルを含む。"
    },
    {
      "id": "grunge",
      "label": "グランジ",
      "period": "1990s",
      "description": "シアトルを中心に、パンクの衝動とヘヴィなギターサウンドを融合させたジャンル。"
    },
    {
      "id": "alternative-rock",
      "label": "オルタナティブロック",
      "period": "1990s-2000s",
      "description": "グランジ以降、メインストリーム化した多様なオルタナティブ・サウンドの総称。"
    },
    {
      "id": "pop-punk-emo",
      "label": "ポップパンク / エモ",
      "period": "1990s-2000s",
      "description": "パンク/ハードコアの語法にポップなメロディや内省的な歌詞を持ち込んだジャンル。"
    },
    {
      "id": "garage-indie-revival",
      "label": "ガレージ / インディーリバイバル",
      "period": "2000s",
      "description": "2000年代、60年代ガレージロックの荒々しさを再解釈したリバイバル・ムーブメント。"
    },
    {
      "id": "other",
      "label": "その他(ルーツロック、アメリカーナ等)",
      "period": "",
      "description": "上記に当てはまらないロック系ジャンル。"
    }
